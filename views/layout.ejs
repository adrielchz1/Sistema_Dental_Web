<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Clínica Dental</title>
  <!-- Bootstrap 5 CDN -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    body {
      padding-top: 20px;
      background-color: #f8f9fa;
    }
    .sidebar {
      background-color: #17a2b8;
      color: white;
      height: 100vh;
      position: fixed;
      padding-top: 20px;
      width: 250px;
    }
    .sidebar .nav-link {
      color: white;
      margin-bottom: 5px;
    }
    .sidebar .nav-link:hover {
      background-color: rgba(255, 255, 255, 0.1);
    }
    .sidebar .nav-link.active {
      background-color: rgba(255, 255, 255, 0.2);
    }
    .main-content {
      margin-left: 270px;
      padding: 20px;
      width: calc(100% - 270px);
    }
    .card {
      margin-bottom: 20px;
      border-radius: 10px;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }
    .card-header {
      background-color: #17a2b8;
      color: white;
      border-radius: 10px 10px 0 0 !important;
    }
    .table-responsive {
      margin-top: 20px;
    }
    .badge-success {
      background-color: #28a745;
    }
    .badge-warning {
      background-color: #ffc107;
    }
    .badge-danger {
      background-color: #dc3545;
    }
  </style>
</head>
<body>
  <% if (!noSidebar) { %>
    <!-- Sidebar -->
    <div class="sidebar">
      <div class="text-center mb-4">
        <h4>Clínica Dental</h4>
        <p class="text-white-50 small">Bienvenido, <%= user.email %></p>
      </div>
      <ul class="nav flex-column">
        <% if (user.rol === 'admin') { %>
          <li class="nav-item">
            <a class="nav-link <%= title === 'Dashboard' ? 'active' : '' %>" href="/admin/dashboard">
              <i class="fas fa-tachometer-alt me-2"></i>Dashboard
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= title === 'Usuarios' ? 'active' : '' %>" href="/admin/usuarios">
              <i class="fas fa-users me-2"></i>Usuarios
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= title === 'Pacientes' ? 'active' : '' %>" href="/admin/pacientes">
              <i class="fas fa-procedures me-2"></i>Pacientes
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= title === 'Historial Médico' ? 'active' : '' %>" href="/admin/historial">
              <i class="fas fa-file-medical me-2"></i>Historial Médico
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= title === 'Tratamientos' ? 'active' : '' %>" href="/admin/tratamientos">
              <i class="fas fa-teeth me-2"></i>Tratamientos
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= title === 'Pagos' ? 'active' : '' %>" href="/admin/pagos">
              <i class="fas fa-money-bill-wave me-2"></i>Pagos
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= title === 'Citas' ? 'active' : '' %>" href="/admin/citas">
              <i class="fas fa-calendar-alt me-2"></i>Citas
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= title === 'Reportes' ? 'active' : '' %>" href="/admin/reportes">
              <i class="fas fa-chart-bar me-2"></i>Reportes
            </a>
          </li>
        <% } else { %>
          <li class="nav-item">
            <a class="nav-link <%= title === 'Dashboard Odontólogo' ? 'active' : '' %>" href="/odontologo/dashboard">
              <i class="fas fa-tachometer-alt me-2"></i>Dashboard
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= title === 'Mis Pacientes' ? 'active' : '' %>" href="/odontologo/pacientes">
              <i class="fas fa-procedures me-2"></i>Mis Pacientes
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= title === 'Historial Médico' ? 'active' : '' %>" href="/odontologo/historial">
              <i class="fas fa-file-medical me-2"></i>Historial Médico
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= title === 'Mis Tratamientos' ? 'active' : '' %>" href="/odontologo/tratamientos">
              <i class="fas fa-teeth me-2"></i>Mis Tratamientos
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= title === 'Pagos de Mis Tratamientos' ? 'active' : '' %>" href="/odontologo/pagos">
              <i class="fas fa-money-bill-wave me-2"></i>Pagos
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= title === 'Mis Citas' ? 'active' : '' %>" href="/odontologo/citas">
              <i class="fas fa-calendar-alt me-2"></i>Mis Citas
            </a>
          </li>
        <% } %>
        <li class="nav-item mt-4">
          <a class="nav-link" href="/logout">
            <i class="fas fa-sign-out-alt me-2"></i>Cerrar Sesión
          </a>
        </li>
      </ul>
    </div>
  <% } %>

  <!-- Main Content -->
  <div class="<%= noSidebar ? '' : 'main-content' %>">
    <% if (!noSidebar) { %>
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><%= title %></h2>
        <span class="badge bg-info"><%= user.rol === 'admin' ? 'Administrador' : 'Odontólogo' %></span>
      </div>
    <% } %>

    <!-- Mensajes Flash -->
    <% if (success_msg && success_msg.length > 0) { %>
      <div class="alert alert-success alert-dismissible fade show" role="alert">
        <%= success_msg %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% } %>
    <% if (error_msg && error_msg.length > 0) { %>
      <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <%= error_msg %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% } %>

    <!-- Contenido de la vista -->
    <%- body %>
  </div>

  <!-- Bootstrap JS Bundle with Popper -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <!-- Chart.js -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</body>
</html>